	column EducationLevel
		dataType: string
		lineageTag: 3b0e65dc-5f2d-4de7-bb74-c820f1fa84ae
		summarizeBy: none
		sourceColumn: EducationLevel

		annotation SummarizationSetBy = Automatic

	column Occupation
		dataType: string
		lineageTag: 73e465e7-0d4f-4a4a-a125-0a4c8f1e1966
		summarizeBy: none
		sourceColumn: Occupation

		annotation SummarizationSetBy = Automatic

	column HomeOwner
		dataType: string
		lineageTag: 4bf5a125-1a80-4818-82e9-3eb78c709302
		summarizeBy: none
		sourceColumn: HomeOwner

